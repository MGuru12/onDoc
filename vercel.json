{
  "version": 2,
  "functions": {
    "server/index.js": {
      "runtime": "nodejs20.x"
    },
    "ai/src/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/index.js"
    },
    {
      "source": "/ai/(.*)",
      "destination": "ai/src/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "client/$1"
    }
  ]
}
