{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/ai/(.*)",
      "destination": "/api/ai"
    },
    {
      "source": "/((?!api|ai).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/auth/cron-cleanup",
      "schedule": "0 0 * * *"
    }
  ]
}